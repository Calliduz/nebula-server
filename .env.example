# Nebula Server Environment Variables

# MongoDB connection string
MONGODB_URI=mongodb+srv://...

# API Keys
TMDB_API_KEY=your_tmdb_api_key
FANART_API_KEY=your_fanart_api_key

# Admin key for protected routes
ADMIN_KEY=your_admin_key

# Optional: Port (defaults to 3001)
PORT=3000

# Security & CORS
# Comma-separated list of allowed origins (e.g. https://nebula.clev.studio,https://nebula.watch)
ALLOWED_ORIGINS=http://localhost:5173

# Frontend URL for link sharing and referer headers
FRONTEND_URL=http://localhost:5173

# Note: .env is ignored by git. Do not commit real secrets.

# FilmU Integration Settings
FILMU_ENABLED=true

# Vidnest Integration Settings
VIDNEST_ENABLED=true

